{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Tenant": {
    "BusinessName": "Meridian Trails",
    "TimeZone": "Europe/Dublin",
    "Locales": ["en-IE"],
    "BusinessHours": {
      "Weekly": [
        { "Day": "Monday", "Open": "09:00", "Close": "17:00" },
        { "Day": "Tuesday", "Open": "09:00", "Close": "17:00" },
        { "Day": "Wednesday", "Open": "09:00", "Close": "17:00" },
        { "Day": "Thursday", "Open": "09:00", "Close": "17:00" },
        { "Day": "Friday", "Open": "09:00", "Close": "17:00" }
      ],
      "Holidays": []
    },
    "Bookings": {
      "BookingCodePattern": "^MT-[A-Z0-9]{8}$",
      "ProductCodePattern": "^MTP-[A-Z0-9]{4}$"
    },
    "Triage": {
      "RulePackPath": "../../../samples/rule-packs/meridian-trails.yaml",
      "PollIntervalSeconds": 60,
      "Urgency": {
        "ProximityHours": 5,
        "DateTimeFormats": ["dd/MM/yyyy HH:mm"]
      }
    }
  },
  "Data": {
    "ConnectionString": "Host=localhost;Port=5432;Database=xenaia;Username=xenaia;Password=change-me",
    "AutoMigrate": true
  },
  "Outbox": {
    "PollIntervalSeconds": 10,
    "BatchSize": 50
  }
}
